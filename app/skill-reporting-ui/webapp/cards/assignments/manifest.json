{
	"sap.app": {
		"id": "com.ndbs.skillreportingui.cards.assignments",
		"type": "card",
		"title": "Recent Assignments"
	},
	"sap.card": {
		"type": "Table",
		"header": {
			"title": "Recent Skill Assignments",
			"subTitle": "Latest recorded skills",
			"icon": {
				"src": "sap-icon://employee-approvals"
			}
		},
		"content": {
			"data": {
				"json": [
					{ "employeeName": "Alice Smith", "skillName": "JavaScript", "proficiencyLevel": "Expert", "validationStatus": "Verified", "source": "System" },
					{ "employeeName": "Alice Smith", "skillName": "Java", "proficiencyLevel": "Advanced", "validationStatus": "Verified", "source": "System" },
					{ "employeeName": "Bob Johnson", "skillName": "JavaScript", "proficiencyLevel": "Intermediate", "validationStatus": "Self Declared", "source": "System" },
					{ "employeeName": "Bob Johnson", "skillName": "AWS", "proficiencyLevel": "Beginner", "validationStatus": "Self Declared", "source": "Manual" },
					{ "employeeName": "Charlie Brown", "skillName": "Communication", "proficiencyLevel": "Expert", "validationStatus": "Manager Confirmed", "source": "Manual" },
					{ "employeeName": "Diana Prince", "skillName": "AWS", "proficiencyLevel": "Advanced", "validationStatus": "Verified", "source": "System" },
					{ "employeeName": "Diana Prince", "skillName": "Communication", "proficiencyLevel": "Expert", "validationStatus": "Manager Confirmed", "source": "Manual" },
					{ "employeeName": "Bob Johnson", "skillName": "Azure", "proficiencyLevel": "Intermediate", "validationStatus": "Self Declared", "source": "Manual" },
					{ "employeeName": "Charlie Brown", "skillName": "JavaScript", "proficiencyLevel": "Beginner", "validationStatus": "Verified", "source": "System" }
				]
			},
			"row": {
				"columns": [
					{
						"title": "Employee",
						"value": "{employeeName}",
						"identifier": true
					},
					{
						"title": "Skill",
						"value": "{skillName}"
					},
					{
						"title": "Proficiency",
						"value": "{proficiencyLevel}"
					},
					{
						"title": "Status",
						"value": "{validationStatus}",
						"state": "{= ${validationStatus} === 'Verified' ? 'Success' : ${validationStatus} === 'Manager Confirmed' ? 'Information' : 'Warning' }"
					}
				]
			}
		}
	}
}
