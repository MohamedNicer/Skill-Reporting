{
	"sap.app": {
		"id": "com.ndbs.skillreportingui.cards.assignments",
		"type": "card",
		"title": "Recent Assignments"
	},
	"sap.card": {
		"type": "Table",
		"header": {
			"title": "Recent Skill Assignments",
			"subTitle": "Latest recorded skills",
			"icon": {
				"src": "sap-icon://employee-approvals"
			},
			"actions": [
				{
					"type": "Navigation",
					"parameters": {
						"url": "#/employee-skills"
					}
				}
			]
		},
		"content": {
			"data": {
				"json": [
					{ "employeeName": "Kevin Bacon", "skillName": "React", "proficiencyLevel": "Beginner", "validationStatus": "Self-Declared" },
					{ "employeeName": "Kevin Bacon", "skillName": "JavaScript", "proficiencyLevel": "Beginner", "validationStatus": "Self-Declared" },
					{ "employeeName": "Laura Palmer", "skillName": "Project Management", "proficiencyLevel": "Intermediate", "validationStatus": "Verified" },
					{ "employeeName": "Ivan Drago", "skillName": "Java", "proficiencyLevel": "Intermediate", "validationStatus": "Self-Declared" },
					{ "employeeName": "Ivan Drago", "skillName": "JavaScript", "proficiencyLevel": "Intermediate", "validationStatus": "Self-Declared" },
					{ "employeeName": "Julia Roberts", "skillName": "Project Management", "proficiencyLevel": "Expert", "validationStatus": "Manager Confirmed" },
					{ "employeeName": "George Miller", "skillName": "Kubernetes", "proficiencyLevel": "Intermediate", "validationStatus": "Self-Declared" },
					{ "employeeName": "George Miller", "skillName": "Docker", "proficiencyLevel": "Advanced", "validationStatus": "Verified" },
					{ "employeeName": "George Miller", "skillName": "Azure", "proficiencyLevel": "Advanced", "validationStatus": "Verified" },
					{ "employeeName": "George Miller", "skillName": "AWS", "proficiencyLevel": "Advanced", "validationStatus": "Verified" }
				]
			},
			"row": {
				"actions": [
					{
						"type": "Navigation",
						"parameters": {
							"url": "#/employee-skills"
						}
					}
				],
				"columns": [
					{
						"title": "Employee",
						"value": "{employeeName}",
						"identifier": true
					},
					{
						"title": "Skill",
						"value": "{skillName}"
					},
					{
						"title": "Proficiency",
						"value": "{proficiencyLevel}"
					},
					{
						"title": "Status",
						"value": "{validationStatus}",
						"state": "{= ${validationStatus} === 'Verified' ? 'Success' : ${validationStatus} === 'Manager Confirmed' ? 'Information' : 'Warning' }"
					}
				]
			}
		}
	}
}
