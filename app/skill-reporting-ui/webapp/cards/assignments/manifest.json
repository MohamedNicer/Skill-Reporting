{
	"sap.app": {
		"id": "com.ndbs.skillreportingui.cards.assignments",
		"type": "card",
		"title": "Recent Assignments"
	},
	"sap.card": {
		"type": "Table",
		"header": {
			"title": "Recent Skill Assignments",
			"subTitle": "Latest recorded skills",
			"icon": {
				"src": "sap-icon://employee-approvals"
			},
			"actions": [
				{
					"type": "Navigation",
					"parameters": {
						"url": "#/employee-skills"
					}
				}
			]
		},
		"data": {
			"request": {
				"url": "/odata/v2/admin/VEmployeeSkills",
				"parameters": {
					"$top": "10",
					"$orderby": "confirmedAt desc"
				}
			},
			"path": "/d/results"
		},
		"content": {
			"row": {
				"actions": [
					{
						"type": "Navigation",
						"parameters": {
							"url": "#/employee-skills"
						}
					}
				],
				"columns": [
					{
						"title": "Employee",
						"value": "{employeeName}",
						"identifier": true
					},
					{
						"title": "Skill",
						"value": "{skillName}"
					},
					{
						"title": "Proficiency",
						"value": "{proficiencyLevel}"
					},
					{
						"title": "Status",
						"value": "{validationStatusText}",
						"state": "{= ${validationStatus} === 'verified' ? 'Success' : ${validationStatus} === 'managerConfirmed' ? 'Information' : 'Warning' }"
					}
				]
			}
		}
	}
}
