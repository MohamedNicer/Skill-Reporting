{
	"sap.app": {
		"id": "com.ndbs.skillreportingui.cards.profile",
		"type": "card",
		"title": "User Profile"
	},
	"sap.card": {
		"type": "Object",
		"configuration": {
			"parameters": {
				"firstName": { "value": "" },
				"lastName": { "value": "" },
				"roleDescription": { "value": "" },
				"email": { "value": "" },
				"successFactorsID": { "value": "" },
				"personnelID": { "value": "" },
				"team": { "value": "" },
				"country": { "value": "" }
			}
		},
		"header": {
			"icon": {
				"src": "sap-icon://customer"
			},
			"title": "{parameters>/firstName/value} {parameters>/lastName/value}",
			"subTitle": "{parameters>/roleDescription/value}"
		},
		"content": {
			"groups": [
				{
					"title": "Contact Details",
					"items": [
						{
							"label": "Email",
							"value": "{parameters>/email/value}"
						},
						{
							"label": "SF ID",
							"value": "{parameters>/successFactorsID/value}"
						}
					]
				},
				{
					"title": "Company Details",
					"items": [
						{
							"label": "Personnel ID",
							"value": "{parameters>/personnelID/value}"
						},
						{
							"label": "Team",
							"value": "{parameters>/team/value}"
						},
						{
							"label": "Country",
							"value": "{parameters>/country/value}"
						}
					]
				}
			]
		}
	}
}
