{
	"sap.app": {
		"id": "com.ndbs.skillreportingui.cards.kpi",
		"type": "card",
		"title": "KPIs"
	},
	"sap.card": {
		"type": "List",
		"header": {
			"title": "Overview",
			"subTitle": "Application Metrics",
			"icon": {
				"src": "sap-icon://business-objects-experience"
			}
		},
		"content": {
			"data": {
				"json": [
					{
						"title": "Total Employees",
						"value": "4",
						"icon": "sap-icon://group",
						"state": "Success",
						"url": "#/employees"
					},
					{
						"title": "Skill Catalog",
						"value": "5",
						"icon": "sap-icon://learning-assistant",
						"state": "None",
						"url": "#/skills"
					},
					{
						"title": "Employee Skills",
						"value": "9",
						"icon": "sap-icon://employee-approvals",
						"state": "Information",
						"url": "#/employee-skills"
					},
					{
						"title": "Pending Requests",
						"value": "5",
						"icon": "sap-icon://message-warning",
						"state": "Error",
						"url": "#/configurations"
					}
				]
			},
			"item": {
				"title": "{title}",
				"icon": {
					"src": "{icon}"
				},
				"info": {
					"value": "{value}",
					"state": "{state}"
				},
				"actions": [
					{
						"type": "Navigation",
						"parameters": {
							"url": "{url}"
						}
					}
				]
			}
		}
	}
}
