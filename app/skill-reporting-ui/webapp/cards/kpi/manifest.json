{
	"sap.app": {
		"id": "com.ndbs.skillreportingui.cards.kpi",
		"type": "card",
		"title": "KPIs"
	},
	"sap.card": {
		"type": "Object",
		"header": {
			"title": "Overview",
			"subTitle": "Live Application Metrics",
			"icon": { "src": "sap-icon://business-objects-experience" }
		},
		"data": {
			"request": {
				"url": "/api/dashboard/kpi()"
			}
		},
		"content": {
			"groups": [
				{
					"title": "Headcount",
					"items": [
						{
							"label": "Total Employees",
							"value": "{employees}",
							"actions": [{ "type": "Navigation", "parameters": { "url": "#/employees" } }]
						}
					]
				},
				{
					"title": "Skills",
					"items": [
						{
							"label": "Approved Skills",
							"value": "{skills}",
							"actions": [{ "type": "Navigation", "parameters": { "url": "#/skills" } }]
						},
						{
							"label": "Skill Assignments",
							"value": "{employeeSkills}",
							"actions": [{ "type": "Navigation", "parameters": { "url": "#/employee-skills" } }]
						}
					]
				},
				{
					"title": "Requests",
					"items": [
						{
							"label": "Pending Reviews",
							"value": "{pendingRequests}",
							"actions": [{ "type": "Navigation", "parameters": { "url": "#/configurations" } }]
						}
					]
				}
			]
		}
	}
}
