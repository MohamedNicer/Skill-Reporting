{
	"sap.app": {
		"id": "com.ndbs.skillreportingui.cards.kpi",
		"type": "card",
		"title": "KPIs"
	},
	"sap.card": {
		"type": "List",
		"header": {
			"title": "Overview",
			"subTitle": "Live Application Metrics",
			"icon": {
				"src": "sap-icon://business-objects-experience"
			}
		},
		"data": {
			"request": {
				"url": "/odata/v2/admin/VEmployees",
				"parameters": {
					"$inlinecount": "allpages",
					"$top": "0"
				}
			},
			"path": "/d"
		},
		"content": {
			"data": {
				"json": [
					{
						"title": "Total Employees",
						"value": "{parameters>/employees/value}",
						"icon": "sap-icon://group",
						"state": "Success",
						"url": "#/employees"
					},
					{
						"title": "Approved Skills",
						"value": "{parameters>/skills/value}",
						"icon": "sap-icon://learning-assistant",
						"state": "None",
						"url": "#/skills"
					},
					{
						"title": "Skill Assignments",
						"value": "{parameters>/employeeSkills/value}",
						"icon": "sap-icon://employee-approvals",
						"state": "Information",
						"url": "#/employee-skills"
					},
					{
						"title": "Pending Requests",
						"value": "{parameters>/pendingRequests/value}",
						"icon": "sap-icon://message-warning",
						"state": "Error",
						"url": "#/configurations"
					}
				]
			},
			"item": {
				"title": "{title}",
				"icon": {
					"src": "{icon}"
				},
				"info": {
					"value": "{value}",
					"state": "{state}"
				},
				"actions": [
					{
						"type": "Navigation",
						"parameters": {
							"url": "{url}"
						}
					}
				]
			}
		},
		"configuration": {
			"parameters": {
				"employees": { "value": "..." },
				"skills": { "value": "..." },
				"employeeSkills": { "value": "..." },
				"pendingRequests": { "value": "..." }
			}
		}
	}
}
