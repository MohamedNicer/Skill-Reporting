{
	"sap.app": {
		"id": "com.ndbs.skillreportingui.cards.kpi",
		"type": "card",
		"title": "KPIs"
	},
	"sap.card": {
		"type": "List",
		"configuration": {
			"parameters": {
				"employees": { "value": 0 },
				"skills": { "value": 0 },
				"employeeSkills": { "value": 0 },
				"pendingRequests": { "value": 0 }
			}
		},
		"header": {
			"title": "Overview",
			"subTitle": "Application Metrics",
			"icon": {
				"src": "sap-icon://business-objects-experience"
			}
		},
		"content": {
			"data": {
				"json": [
					{
						"title": "Total Employees",
						"value": "{parameters>/employees/value}",
						"icon": "sap-icon://group",
						"state": "Success"
					},
					{
						"title": "Skill Catalog",
						"value": "{parameters>/skills/value}",
						"icon": "sap-icon://learning-assistant",
						"state": "None"
					},
					{
						"title": "Employee Skills",
						"value": "{parameters>/employeeSkills/value}",
						"icon": "sap-icon://employee-approvals",
						"state": "None"
					},
					{
						"title": "Pending Requests",
						"value": "{parameters>/pendingRequests/value}",
						"icon": "sap-icon://message-warning",
						"state": "Error"
					}
				]
			},
			"item": {
				"title": "{title}",
				"icon": {
					"src": "{icon}"
				},
				"info": {
					"value": "{value}",
					"state": "{state}"
				}
			}
		}
	}
}
