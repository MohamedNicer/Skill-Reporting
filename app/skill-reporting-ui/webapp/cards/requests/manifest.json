{
	"sap.app": {
		"id": "com.ndbs.skillreportingui.cards.requests",
		"type": "card",
		"title": "Pending Requests"
	},
	"sap.card": {
		"type": "List",
		"header": {
			"title": "Pending Skill Requests",
			"subTitle": "Awaiting admin approval",
			"icon": { "src": "sap-icon://message-warning" },
			"actions": [{ "type": "Navigation", "parameters": { "url": "#/skill-requests" } }]
		},
		"data": {
			"request": {
				"url": "/odata/v2/admin/SkillRequests",
				"parameters": {
					"$top": "10",
					"$filter": "status eq 'pendingReview'",
					"$orderby": "requestedAt desc",
					"$expand": "toRequestedBy"
				}
			},
			"path": "/d/results"
		},
		"content": {
			"item": {
				"title": "{toRequestedBy/firstName} {toRequestedBy/lastName}",
				"description": "{requestedText}",
				"icon": { "src": "sap-icon://person-placeholder" },
				"info": { "value": "Pending Review", "state": "Warning" },
				"actions": [{ "type": "Navigation", "parameters": { "url": "#/skill-requests" } }]
			}
		}
	}
}
