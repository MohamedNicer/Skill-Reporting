<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
>
    <Dialog
        id="diaSettings"
        showHeader="true"
        title="{i18n>settings}"
    >
        <content>
            <form:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="3"
                labelSpanL="3"
                labelSpanM="3"
                labelSpanS="12"
                adjustLabelSpan="false"
                emptySpanXL="4"
                emptySpanL="4"
                emptySpanM="4"
                emptySpanS="0"
                columnsXL="1"
                columnsL="1"
                columnsM="1"
                singleContainerFullSize="false"
            >
                <form:content>
                    <Label text="{i18n>theme}" />
                    <RadioButtonGroup id="rbgTheme">
                        <RadioButton
                            id="rbHorizonHCW"
                            text="{i18n>horizonHCW}"
                        />
                        <RadioButton
                            id="rbHorizonHCB"
                            text="{i18n>horizonHCB}"
                        />
                        <RadioButton
                            id="rbEveningHorizon"
                            text="{i18n>eveningHorizon}"
                        />
                        <RadioButton
                            id="rbMorningHorizon"
                            text="{i18n>morningHorizon}"
                        />
                        <RadioButton
                            id="rbQuartzDark"
                            text="{i18n>quartzDark}"
                        />
                        <RadioButton
                            id="rbQuartzLight"
                            text="{i18n>quartzLight}"
                        />
                        <RadioButton
                            id="rbHighContrastBlack"
                            text="{i18n>highContrastBlack}"
                        />
                        <RadioButton
                            id="rbHighContrastWhite"
                            text="{i18n>highContrastWhite}"
                        />
                        <RadioButton
                            id="rbBelize"
                            text="{i18n>belize}"
                        />
                    </RadioButtonGroup>
                </form:content>
            </form:SimpleForm>
        </content>
        <beginButton>
            <Button
                text="{i18n>save}"
                press="onSaveSettings"
            />
        </beginButton>
        <endButton>
            <Button
                text="Close"
                press="onCloseSettingsDialog"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
