<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:table="sap.ui.table"
    xmlns:form="sap.ui.layout.form"
>
    <Dialog
        id="diaClaimRole"
        title="{i18n>claimRoleDialogTitle}"
        contentWidth="60rem"
    >
        <content>
            <MessageStrip
                text="{i18n>selectAdministrators}"
                type="Information"
                showCloseButton="false"
                showIcon="true"
                class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginTop"
            />
            <form:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="3"
                labelSpanL="3"
                labelSpanM="3"
                labelSpanS="3"
                adjustLabelSpan="false"
                emptySpanXL="4"
                emptySpanL="4"
                emptySpanM="4"
                emptySpanS="4"
                columnsXL="1"
                columnsL="1"
                columnsM="1"
                singleContainerFullSize="false"
            >
                <form:content>
                    <Label text="{i18n>successFactorsID}" />
                    <Text text="{whoamiModel>/successFactorsID}" />
                    <Label
                        text="{i18n>personnelID}"
                        visible="{= ${whoamiModel>/personnelID} !== null}"
                    />
                    <Text
                        text="{whoamiModel>/personnelID}"
                        visible="{= ${whoamiModel>/personnelID} !== null}"
                    />
                    <Label text="{i18n>firstName}" />
                    <Text text="{whoamiModel>/firstName}" />
                    <Label text="{i18n>lastName}" />
                    <Text text="{whoamiModel>/lastName}" />
                    <Label
                        text="{i18n>country}"
                        visible="{= ${whoamiModel>/country} !== null}"
                    />
                    <Text
                        text="{whoamiModel>/country}"
                        visible="{= ${whoamiModel>/country} !== null}"
                    />
                    <Label
                        text="{i18n>team}"
                        visible="{= ${whoamiModel>/team} !== null}"
                    />
                    <Text
                        text="{whoamiModel>/team}"
                        visible="{= ${whoamiModel>/team} !== null}"
                    />
                    <Label text="{i18n>myRole}" />
                    <Text text="{whoamiModel>/roleDescription}" />
                    <Label text="{i18n>claimedRole}" />
                    <ComboBox
                        id="cbClaimedRole"
                        items="{/ApplicationRoleList}"
                    >
                        <items>
                            <core:Item
                                key="{role}"
                                text="{description}"
                            />
                        </items>
                    </ComboBox>
                    <Label text="{i18n>reason}" />
                    <TextArea
                        id="txtReason"
                        rows="6"
                        maxLength="255"
                    />
                </form:content>
            </form:SimpleForm>
            <smartTable:SmartTable
                id="stClaimRole"
                entitySet="ApplicationAdmins"
                tableType="ResponsiveTable"
                enableExport="true"
                enableAutoBinding="true"
                useVariantManagement="false"
                header="{i18n>administrators}"
                useTablePersonalisation="false"
                showRowCount="true"
                class="sapUiResponsiveContentPadding"
                enableAutoColumnWidth="true"
                editTogglable="false"
            >
                <Table
                    id="tblClaimRole"
                    mode="MultiSelect"
                />
            </smartTable:SmartTable>
        </content>
        <beginButton>
            <Button
                text="{i18n>claim}"
                press="onClaimRole"
            />
        </beginButton>
        <endButton>
            <Button
                text="Close"
                press="onCloseClaimRoleDialog"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
