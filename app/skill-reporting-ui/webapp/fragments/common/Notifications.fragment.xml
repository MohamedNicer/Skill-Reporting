<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Popover
        showHeader="false"
        placement="Bottom"
        class="sapUiContentPadding"
        contentWidth="50rem"
    >
        <content>
            <NotificationList
                id="nlNotifications"
                items="{path: '/NotificationGroups', templateShareable:true}"
            >
                <layoutData>
                    <FlexItemData maxWidth="600px" />
                </layoutData>
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{i18n>notifications}" />
                        <ToolbarSpacer />
                        <Button
                            id="btnDeleteAllNotifications"
                            text="{i18n>deleteAll}"
                            press="onDeleteAllNotifications"
                            enabled="false"
                        />
                    </OverflowToolbar>
                </headerToolbar>
                <NotificationListGroup
                    title="{notificationGroup}"
                    items="{path: 'toNotifications', templateShareable:true}"
                    showCloseButton="false"
                >
                    <NotificationListItem
                        title="{title}"
                        description="{description}"
                        unread="{unread}"
                        close="onDeleteNotification"
                        priority="{priority}"
                        authorName="{authorName}"
                        authorAvatarColor="{authorAvatarColor}"
                        authorPicture="{authorPicture}"
                        datetime="{path:'createdAt', type: 'sap.ui.model.type.DateTime', formatOptions:{pattern:'dd MMMM y HH:mm:ss'}}"
                    />
                </NotificationListGroup>
            </NotificationList>
        </content>
    </Popover>
</core:FragmentDefinition>
