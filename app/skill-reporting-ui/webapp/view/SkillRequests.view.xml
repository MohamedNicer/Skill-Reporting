<mvc:View
    controllerName="com.ndbs.skillreportingui.controller.SkillRequests"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:smartFilterBar="sap.ui.comp.smartfilterbar"
>
    <Page id="SkillRequests" showHeader="true" title="{i18n>skillRequests}" showNavButton="true" navButtonPress=".onNavBack">
        <VBox fitContainer="true" class="sapUiResponsiveContentPadding">
            <smartFilterBar:SmartFilterBar
                id="sfbSkillRequests"
                entitySet="VSkillRequests"
                model="profile"
                enableBasicSearch="true"
            />
            <smartTable:SmartTable
                id="stSkillRequests"
                entitySet="VSkillRequests"
                model="profile"
                smartFilterId="sfbSkillRequests"
                tableType="ResponsiveTable"
                enableAutoBinding="true"
                useVariantManagement="false"
                useTablePersonalisation="true"
                showFullScreenButton="true"
                showRowCount="true"
                editTogglable="false"
                header="{i18n>skillRequests}"
                requestAtLeastFields="status,statusText,requestedByID,requestedByName,requestedText,requestType,requestTypeText,decision,decisionText,requestedAt"
            >
                <smartTable:customToolbar>
                    <OverflowToolbar design="Transparent">
                        <ToolbarSpacer />
                        <Button
                            id="btnApproveRequest"
                            text="{i18n>approve}"
                            icon="sap-icon://accept"
                            press="onApproveRequest"
                            enabled="false"
                        />
                        <Button
                            id="btnRejectRequest"
                            text="{i18n>reject}"
                            icon="sap-icon://decline"
                            press="onRejectRequest"
                            enabled="false"
                        />
                    </OverflowToolbar>
                </smartTable:customToolbar>
                <Table
                    id="tblSkillRequests"
                    sticky="ColumnHeaders,HeaderToolbar"
                    selectionChange="onSkillRequestSelectionChange"
                    mode="SingleSelectLeft"
                    growing="true"
                    growingThreshold="10"
                    growingScrollToLoad="false"
                >
                    <columns>
                        <Column>
                            <customData>
                                <core:CustomData key="p13nData" value='\{"columnKey": "requestedByName", "leadingProperty": "requestedByName", "sortProperty": "requestedByName", "filterProperty": "requestedByName"\}' />
                            </customData>
                            <Text text="Requested By" />
                        </Column>
                        <Column>
                            <customData>
                                <core:CustomData key="p13nData" value='\{"columnKey": "requestTypeText", "leadingProperty": "requestTypeText", "sortProperty": "requestTypeText", "filterProperty": "requestTypeText"\}' />
                            </customData>
                            <Text text="Request Type" />
                        </Column>
                        <Column>
                            <customData>
                                <core:CustomData key="p13nData" value='\{"columnKey": "requestedText", "leadingProperty": "requestedText", "sortProperty": "requestedText", "filterProperty": "requestedText"\}' />
                            </customData>
                            <Text text="Requested Skill / Details" />
                        </Column>
                        <Column>
                            <customData>
                                <core:CustomData key="p13nData" value='\{"columnKey": "statusText", "leadingProperty": "statusText", "sortProperty": "statusText", "filterProperty": "statusText"\}' />
                            </customData>
                            <Text text="Status" />
                        </Column>
                        <Column>
                            <customData>
                                <core:CustomData key="p13nData" value='\{"columnKey": "decisionText", "leadingProperty": "decisionText", "sortProperty": "decisionText", "filterProperty": "decisionText"\}' />
                            </customData>
                            <Text text="Decision / Notes" />
                        </Column>
                        <Column>
                            <customData>
                                <core:CustomData key="p13nData" value='\{"columnKey": "requestedAt", "leadingProperty": "requestedAt", "sortProperty": "requestedAt", "filterProperty": "requestedAt"\}' />
                            </customData>
                            <Text text="Date" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <ObjectIdentifier title="{requestedByName}" text="{requestedByID}" />
                                <Text text="{requestTypeText}" />
                                <Text text="{requestedText}" />
                                <ObjectStatus
                                    text="{statusText}"
                                    state="{= ${status} === 'approved' || ${status} === 'Approved' || ${status} === 'decided' || ${status} === 'Decided' ? 'Success' : ${status} === 'rejected' || ${status} === 'Rejected' ? 'Error' : 'Warning' }"
                                />
                                <Text text="{decisionText}" />
                                <Text text="{
                                    path: 'requestedAt',
                                    type: 'sap.ui.model.type.Date',
                                    formatOptions: { style: 'medium' }
                                }" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </smartTable:SmartTable>
        </VBox>
        <footer>
            <OverflowToolbar id="otbFooter">
                <Button
                    id="btnMessages"
                    icon="sap-icon://alert"
                    text="{=${message>/}.length}"
                    type="Emphasized"
                    press="onMessagePopoverPress"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
