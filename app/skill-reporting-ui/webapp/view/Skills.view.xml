<mvc:View
    controllerName="com.ndbs.skillreportingui.controller.Skills"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:smartFilterBar="sap.ui.comp.smartfilterbar"
    xmlns:smartTable="sap.ui.comp.smarttable"
>
    <Page id="Skills" showHeader="false">
        <FlexBox justifyContent="Center" alignItems="Center">
            <VBox width="95%">
                <smartFilterBar:SmartFilterBar
                    id="sfbSkills"
                    entitySet="VSkills"
                    enableBasicSearch="true"
                />
                <smartTable:SmartTable
                    id="stSkills"
                    entitySet="VSkills"
                    smartFilterId="sfbSkills"
                    tableType="ResponsiveTable"
                    enableAutoBinding="true"
                    enableExport="true"
                    useVariantManagement="false"
                    useTablePersonalisation="true"
                    showFullScreenButton="true"
                    showRowCount="true"
                    editTogglable="false"
                    header="{i18n>skillCatalog}"
                >
                    <smartTable:customToolbar>
                        <OverflowToolbar design="Transparent">
                            <ToolbarSpacer />
                            <OverflowToolbarButton
                                id="btnCreateSkill"
                                icon="sap-icon://add"
                                tooltip="{i18n>createSkill}"
                                press="onCreateSkill"

                            />
                            <OverflowToolbarButton
                                id="btnUpdateSkill"
                                icon="sap-icon://edit"
                                tooltip="{i18n>editSkill}"
                                press="onUpdateSkill"
                                enabled="false"

                            />
                            <OverflowToolbarButton
                                id="btnDeprecateSkill"
                                icon="sap-icon://decline"
                                tooltip="{i18n>deprecateSkill}"
                                press="onDeprecateSkill"
                                enabled="false"

                            />
                        </OverflowToolbar>
                    </smartTable:customToolbar>
                    <Table
                        id="tblSkills"
                        sticky="ColumnHeaders,HeaderToolbar"
                        selectionChange="onSkillSelectionChange"
                        mode="SingleSelectLeft"
                    >
                        <columns>
                            <Column width="4rem" hAlign="Center">
                                <customData>
                                    <core:CustomData key="p13nData" value='\{"columnKey": "imageUrl", "leadingProperty": "imageUrl"\}' />
                                </customData>
                                <Text text="Logo" />
                            </Column>
                            <Column>
                                <customData>
                                    <core:CustomData key="p13nData" value='\{"columnKey": "canonicalName", "leadingProperty": "canonicalName", "sortProperty": "canonicalName", "filterProperty": "canonicalName"\}' />
                                </customData>
                                <Text text="{i18n>skillName}" />
                            </Column>
                            <Column>
                                <customData>
                                    <core:CustomData key="p13nData" value='\{"columnKey": "categoryName", "leadingProperty": "categoryName", "sortProperty": "categoryName", "filterProperty": "categoryName"\}' />
                                </customData>
                                <Text text="Category" />
                            </Column>
                            <Column>
                                <customData>
                                    <core:CustomData key="p13nData" value='\{"columnKey": "statusText", "leadingProperty": "statusText", "sortProperty": "statusText", "filterProperty": "statusText"\}' />
                                </customData>
                                <Text text="Status" />
                            </Column>
                            <Column>
                                <customData>
                                    <core:CustomData key="p13nData" value='\{"columnKey": "description", "leadingProperty": "description"\}' />
                                </customData>
                                <Text text="Description" />
                            </Column>
                            <Column hAlign="Center" width="5rem">
                                <customData>
                                    <core:CustomData key="p13nData" value='\{"columnKey": "isActive", "leadingProperty": "isActive", "sortProperty": "isActive", "filterProperty": "isActive"\}' />
                                </customData>
                                <Text text="Active" />
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Avatar
                                        src="{ path: 'imageUrl', formatter: '.formatter.getImageUrl' }"
                                        displaySize="S"
                                        displayShape="Square"
                                        imageFitType="Contain"
                                        backgroundColor="Transparent"
                                        fallbackIcon="sap-icon://learning-assistant"
                                    />
                                    <ObjectIdentifier
                                        title="{canonicalName}"
                                        text="{normalizedName}"
                                    />
                                    <Text text="{categoryName}" />
                                    <ObjectStatus
                                        text="{statusText}"
                                        state="{= ${status} === 'approved' ? 'Success' : ${status} === 'deprecated' ? 'Error' : 'Warning' }"
                                    />
                                    <Text text="{description}" wrapping="false" />
                                    <core:Icon
                                        src="{= ${isActive} ? 'sap-icon://accept' : 'sap-icon://decline'}"
                                        color="{= ${isActive} ? '#107E3E' : '#BB0000'}"
                                    />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </smartTable:SmartTable>
            </VBox>
        </FlexBox>
        <footer>
            <OverflowToolbar id="otbFooter">
                <Button
                    id="btnMessages"
                    icon="sap-icon://alert"
                    text="{=${message>/}.length}"
                    type="Emphasized"
                    press="onMessagePopoverPress"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
