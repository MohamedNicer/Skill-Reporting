<mvc:View
    controllerName="com.ndbs.skillreportingui.controller.Skills"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
>
    <Page id="Skills" showHeader="true" title="{i18n>skillCatalog}" showNavButton="true" navButtonPress=".onNavBack">
        <subHeader>
            <OverflowToolbar>
                <SearchField id="sfSkills" width="100%" placeholder="Search skills by name, category, or description..." search=".onSearch" liveChange=".onSearch" />
            </OverflowToolbar>
        </subHeader>

        <VBox fitContainer="true" class="sapUiResponsiveContentPadding">
            <!-- Top KPI Summary Bar -->
            <HBox class="kpi-container sapUiMediumMarginBottom" justifyContent="SpaceAround" alignItems="Center">
                <VBox alignItems="Center">
                    <Label text="Total Catalog Skills" class="sapUiTinyMarginBottom" />
                    <ObjectNumber number="{groupedSkillsModel>/totalCount}" state="None" />
                </VBox>
                <VBox alignItems="Center">
                    <Label text="Approved Skills" class="sapUiTinyMarginBottom" />
                    <ObjectNumber number="{groupedSkillsModel>/approvedCount}" state="Success" />
                </VBox>
                <VBox alignItems="Center">
                    <Label text="Skill Categories" class="sapUiTinyMarginBottom" />
                    <ObjectNumber number="{groupedSkillsModel>/categoriesCount}" state="Information" />
                </VBox>
            </HBox>

            <Title text="Skill Categories" level="H3" class="section-title" />

            <!-- Collapsible Category Panels -->
            <VBox items="{groupedSkillsModel>/categories}">
                <items>
                    <Panel
                        expandable="true"
                        expanded="false"
                        class="custom-category-panel sapUiSmallMarginBottom"
                    >
                        <headerToolbar>
                            <OverflowToolbar design="Transparent" class="custom-category-header">
                                <Avatar src="{groupedSkillsModel>icon}" displaySize="XS" class="category-icon-avatar sapUiTinyMarginEnd" />
                                <Title text="{groupedSkillsModel>categoryName}" level="H4" style="H4" />
                                <ToolbarSpacer />
                                <ObjectStatus text="{groupedSkillsModel>count} Skills" state="None" class="badge-count sapUiTinyMarginEnd" />
                            </OverflowToolbar>
                        </headerToolbar>

                        <Table items="{groupedSkillsModel>skills}" mode="None">
                            <columns>
                                <Column><Text text="Skill" /></Column>
                                <Column><Text text="Category" /></Column>
                                <Column><Text text="Description" /></Column>
                                <Column><Text text="Status" /></Column>
                                <Column hAlign="Center"><Text text="Active" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <HBox alignItems="Center">
                                            <Avatar src="{groupedSkillsModel>imageUrl}" displaySize="XS" fallbackIcon="sap-icon://education" class="sapUiTinyMarginEnd" />
                                            <Text text="{groupedSkillsModel>canonicalName}" />
                                        </HBox>
                                        <Text text="{groupedSkillsModel>categoryName}" />
                                        <Text text="{groupedSkillsModel>description}" />
                                        <ObjectStatus
                                            text="{groupedSkillsModel>statusText}"
                                            state="{= ${groupedSkillsModel>status} === 'approved' || ${groupedSkillsModel>status} === 'Approved' ? 'Success' : ${groupedSkillsModel>status} === 'deprecated' ? 'Error' : 'Warning'}"
                                        />
                                        <core:Icon
                                            src="{= ${groupedSkillsModel>isActive} ? 'sap-icon://accept' : 'sap-icon://decline'}"
                                            color="{= ${groupedSkillsModel>isActive} ? '#2e7d32' : '#c62828'}"
                                        />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </Panel>
                </items>
            </VBox>
        </VBox>

        <footer>
            <OverflowToolbar id="otbFooter">
                <ToolbarSpacer />
                <Button
                    id="btnMessages"
                    icon="sap-icon://alert"
                    text="{=${message>/}.length}"
                    type="Emphasized"
                    press="onMessagePopoverPress"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
