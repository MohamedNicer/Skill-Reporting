<mvc:View controllerName="com.ndbs.skillreportingui.controller.NoAuthorization"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:f="sap.f">
    <Page id="NoAuthorization"
        showHeader="false">
        <FlexBox justifyContent="Center"
            alignItems="Center"
            height="100%">
            <IllustratedMessage id="imNoAuthMessage"
                title="{i18n>noAuthorization}"
                illustrationSize="Scene"
                illustrationType="tnt-UnsuccessfulAuth">
                <additionalContent>
                    <Button text="{i18n>returnHomepage}"
                        press="onNavToView('RouteHomepage')"/>
                </additionalContent>
            </IllustratedMessage>
        </FlexBox>
    </Page>
</mvc:View>
