<mvc:View
    controllerName="com.ndbs.skillreportingui.controller.Homepage"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:smartFilterBar="sap.ui.comp.smartfilterbar"
    xmlns:w="sap.ui.integration.widgets"
    xmlns:grid="sap.ui.layout.cssgrid"
>
    <Page id="Homepage" showHeader="false">
        <VBox class="sapUiMediumMarginTop sapUiSmallMarginBeginEnd">

            <grid:CSSGrid gridGap="1rem" gridTemplateColumns="repeat(auto-fit, minmax(22rem, 1fr))">
                <grid:items>
                    <w:Card manifest="./cards/profile/manifest.json" parameters="{globalJSONModel>/cards/profile}">
                        <w:layoutData>
                            <grid:GridItemLayoutData gridColumn="span 1" />
                        </w:layoutData>
                    </w:Card>

                    <w:Card manifest="./cards/kpi/manifest.json" parameters="{globalJSONModel>/kpi}">
                        <w:layoutData>
                            <grid:GridItemLayoutData gridColumn="span 1" />
                        </w:layoutData>
                    </w:Card>

                    <w:Card manifest="./cards/assignments/manifest.json" parameters="{globalJSONModel>/cards}">
                        <w:layoutData>
                            <grid:GridItemLayoutData gridColumn="span 2" />
                        </w:layoutData>
                    </w:Card>

                    <w:Card manifest="./cards/requests/manifest.json" parameters="{globalJSONModel>/cards}">
                        <w:layoutData>
                            <grid:GridItemLayoutData gridColumn="span 2" />
                        </w:layoutData>
                    </w:Card>
                </grid:items>
            </grid:CSSGrid>

        </VBox>
        <footer>
            <OverflowToolbar id="otbFooter">
                <Button
                    id="btnMessages"
                    icon="sap-icon://alert"
                    text="{=${message>/}.length}"
                    type="Emphasized"
                    press="onMessagePopoverPress"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
