<mvc:View
    controllerName="com.ndbs.skillreportingui.controller.Homepage"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:smartFilterBar="sap.ui.comp.smartfilterbar"
    xmlns:w="sap.ui.integration.widgets"
    xmlns:grid="sap.ui.layout.cssgrid"
>
    <Page id="Homepage" showHeader="false">
        <IconTabBar id="itbLaunchpad" class="sapUiNoContentPadding" headerBackgroundDesign="Solid" applyContentPadding="false">
            <items>
                <!-- Overview: Cards Dashboard -->
                <IconTabFilter text="{i18n>overview}" key="overview">
                    <VBox class="sapUiMediumMarginTop sapUiSmallMarginBeginEnd">
                        <grid:CSSGrid gridGap="1rem" gridTemplateColumns="repeat(auto-fit, minmax(22rem, 1fr))">
                            <grid:items>
                                <w:Card manifest="./cards/profile/manifest.json">
                                    <w:layoutData>
                                        <grid:GridItemLayoutData gridColumn="span 1" />
                                    </w:layoutData>
                                </w:Card>

                                <w:Card id="cardKpi" manifest="./cards/kpi/manifest.json">
                                    <w:layoutData>
                                        <grid:GridItemLayoutData gridColumn="span 1" />
                                    </w:layoutData>
                                </w:Card>

                                <w:Card manifest="./cards/assignments/manifest.json">
                                    <w:layoutData>
                                        <grid:GridItemLayoutData gridColumn="span 2" />
                                    </w:layoutData>
                                </w:Card>

                                <w:Card manifest="./cards/requests/manifest.json">
                                    <w:layoutData>
                                        <grid:GridItemLayoutData gridColumn="span 2" />
                                    </w:layoutData>
                                </w:Card>
                            </grid:items>
                        </grid:CSSGrid>
                    </VBox>
                </IconTabFilter>

                <!-- Personnel & Skills -->
                <IconTabFilter text="{i18n>personnelSkills}" key="personnel_skills">
                    <HBox class="sapUiMediumMargin" wrap="Wrap">
                        <GenericTile
                            header="{i18n>personnel}"
                            subheader="{i18n>employeeDirectory}"
                            press=".onNavToView('RoutePersonnel')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <NumericContent icon="sap-icon://company-view" valueColor="Neutral" />
                            </TileContent>
                        </GenericTile>

                        <GenericTile
                            header="{i18n>skillCatalog}"
                            subheader="{i18n>manageSkills}"
                            press=".onNavToView('RouteSkills')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <NumericContent icon="sap-icon://education" valueColor="Neutral" />
                            </TileContent>
                        </GenericTile>
                    </HBox>
                </IconTabFilter>

                <!-- Operations -->
                <IconTabFilter text="{i18n>operations}" key="operations">
                    <HBox class="sapUiMediumMargin" wrap="Wrap">
                        <GenericTile
                            header="{i18n>employeeSkills}"
                            subheader="{i18n>skillAssignments}"
                            press=".onNavToView('RouteEmployeeSkills')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <NumericContent icon="sap-icon://employee-approvals" valueColor="Neutral" />
                            </TileContent>
                        </GenericTile>

                        <GenericTile
                            header="{i18n>cvCenter}"
                            subheader="{i18n>uploadCV}"
                            press=".onNavToView('RouteCVCenter')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <NumericContent icon="sap-icon://document" valueColor="Neutral" />
                            </TileContent>
                        </GenericTile>
                    </HBox>
                </IconTabFilter>

                <!-- Management -->
                <IconTabFilter text="{i18n>management}" key="management">
                    <HBox class="sapUiMediumMargin" wrap="Wrap">
                        <GenericTile
                            header="{i18n>managerWorkspace}"
                            subheader="{i18n>teamSkills}"
                            press=".onNavToView('RouteManagerWorkspace')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <NumericContent icon="sap-icon://manager" valueColor="Neutral" />
                            </TileContent>
                        </GenericTile>

                        <GenericTile
                            header="{i18n>reports}"
                            subheader="{i18n>analytics}"
                            press=".onNavToView('RouteReports')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <NumericContent icon="sap-icon://business-objects-experience" valueColor="Neutral" />
                            </TileContent>
                        </GenericTile>
                    </HBox>
                </IconTabFilter>

                <!-- Administration -->
                <IconTabFilter text="{i18n>administration}" key="administration">
                    <HBox class="sapUiMediumMargin" wrap="Wrap">
                        <GenericTile
                            header="{i18n>configurations}"
                            subheader="{i18n>systemSettings}"
                            press=".onNavToView('RouteConfigurations')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <NumericContent icon="sap-icon://settings" valueColor="Neutral" />
                            </TileContent>
                        </GenericTile>
                    </HBox>
                </IconTabFilter>
            </items>
        </IconTabBar>
        <footer>
            <OverflowToolbar id="otbFooter">
                <Button
                    id="btnMessages"
                    icon="sap-icon://alert"
                    text="{=${message>/}.length}"
                    type="Emphasized"
                    press="onMessagePopoverPress"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
