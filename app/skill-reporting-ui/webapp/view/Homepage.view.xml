<mvc:View
    controllerName="com.ndbs.skillreportingui.controller.Homepage"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:smartFilterBar="sap.ui.comp.smartfilterbar"
    xmlns:w="sap.ui.integration.widgets"
    xmlns:grid="sap.ui.layout.cssgrid"
>
    <Page id="Homepage" showHeader="false">
        <IconTabBar id="itbLaunchpad" class="sapUiNoContentPadding" headerBackgroundDesign="Solid" applyContentPadding="false" select=".onTabSelect">
            <items>
                <!-- Overview: Cards Dashboard -->
                <IconTabFilter text="{i18n>overview}" key="overview">
                    <VBox class="sapUiMediumMarginTop sapUiSmallMarginBeginEnd">
                        <grid:CSSGrid class="gridAlignStart" gridGap="1rem" gridTemplateColumns="repeat(auto-fit, minmax(22rem, 1fr))">
                            <grid:items>
                                <!-- Profile card commented out — use 'Who am I?' in the ShellBar personal menu instead
                                <w:Card manifest="./cards/profile/manifest.json">
                                    <w:layoutData>
                                        <grid:GridItemLayoutData gridColumn="span 1" />
                                    </w:layoutData>
                                </w:Card>
                                -->

                                <w:Card id="cardKpi" manifest="./cards/kpi/manifest.json">
                                    <w:layoutData>
                                        <grid:GridItemLayoutData gridColumn="span 1" />
                                    </w:layoutData>
                                </w:Card>

                                <w:Card manifest="./cards/assignments/manifest.json">
                                    <w:layoutData>
                                        <grid:GridItemLayoutData gridColumn="span 2" />
                                    </w:layoutData>
                                </w:Card>

                                <w:Card manifest="./cards/requests/manifest.json" visible="{= ${userRolesModel>/isAdmin}}">
                                    <w:layoutData>
                                        <grid:GridItemLayoutData gridColumn="span 2" />
                                    </w:layoutData>
                                </w:Card>

                                <w:Card manifest="./cards/topSkills/manifest.json">
                                    <w:layoutData>
                                        <grid:GridItemLayoutData gridColumn="span 1" />
                                    </w:layoutData>
                                </w:Card>

                                <w:Card manifest="./cards/skillsByCategory/manifest.json">
                                    <w:layoutData>
                                        <grid:GridItemLayoutData gridColumn="span 2" gridRow="span 2" />
                                    </w:layoutData>
                                </w:Card>

                                <w:Card manifest="./cards/requestsStatus/manifest.json" visible="{= ${userRolesModel>/isAdmin}}">
                                    <w:layoutData>
                                        <grid:GridItemLayoutData gridColumn="span 1" />
                                    </w:layoutData>
                                </w:Card>
                            </grid:items>
                        </grid:CSSGrid>
                    </VBox>
                </IconTabFilter>

                <!-- Personnel & Skills -->
                <IconTabFilter text="{i18n>personnelSkills}" key="personnel_skills">
                    <HBox class="sapUiMediumMargin" wrap="Wrap">
                        <GenericTile
                            header="{i18n>personnel}"
                            subheader="{i18n>employeeDirectory}"
                            press=".onNavToView('RoutePersonnel')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <NumericContent value="{dashboardModel>/employees}" icon="sap-icon://company-view" valueColor="Good" />
                            </TileContent>
                        </GenericTile>

                        <GenericTile
                            header="{i18n>skillCatalog}"
                            subheader="{i18n>manageSkills}"
                            press=".onNavToView('RouteSkills')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <NumericContent value="{dashboardModel>/skills}" icon="sap-icon://education" valueColor="Neutral" />
                            </TileContent>
                        </GenericTile>
                    </HBox>
                </IconTabFilter>

                <!-- Operations -->
                <IconTabFilter text="{i18n>operations}" key="operations">
                    <HBox class="sapUiMediumMargin" wrap="Wrap">
                        <GenericTile
                            header="{i18n>employeeSkills}"
                            subheader="{i18n>skillAssignments}"
                            press=".onNavToView('RouteEmployeeSkills')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <NumericContent value="{dashboardModel>/employeeSkills}" icon="sap-icon://employee-approvals" valueColor="Good" />
                            </TileContent>
                        </GenericTile>

                        <GenericTile
                            header="{i18n>uploadedCVs}"
                            subheader="{i18n>manageUploadedCVs}"
                            press=".onNavToView('RouteUploadedCVs')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <ImageContent src="sap-icon://upload-to-cloud" />
                            </TileContent>
                        </GenericTile>

                        <GenericTile
                            header="{i18n>generatedCVs}"
                            subheader="{i18n>manageGeneratedCVs}"
                            press=".onNavToView('RouteGeneratedCVs')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <ImageContent src="sap-icon://pdf-attachment" />
                            </TileContent>
                        </GenericTile>
                    </HBox>
                </IconTabFilter>

                <!-- Management -->
                <IconTabFilter text="{i18n>management}" key="management" visible="{= ${userRolesModel>/isManagerOrAbove}}">
                    <HBox class="sapUiMediumMargin" wrap="Wrap">
                        <GenericTile
                            header="{i18n>teamSkills}"
                            subheader="{i18n>managerWorkspace}"
                            press=".onNavToView('RouteTeamSkills')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <ImageContent src="sap-icon://manager" />
                            </TileContent>
                        </GenericTile>

                        <GenericTile
                            header="{i18n>departmentHeatmap}"
                            subheader="{i18n>analytics}"
                            press=".onNavToView('RouteDepartmentHeatmap')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <ImageContent src="sap-icon://business-objects-experience" />
                            </TileContent>
                        </GenericTile>

                        <GenericTile
                            header="{i18n>cvActivity}"
                            subheader="{i18n>analytics}"
                            press=".onNavToView('RouteCVActivity')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <ImageContent src="sap-icon://activity-2" />
                            </TileContent>
                        </GenericTile>
                    </HBox>
                </IconTabFilter>

                <!-- Administration -->
                <IconTabFilter text="{i18n>administration}" key="administration" visible="{= ${userRolesModel>/isAdmin} || ${userRolesModel>/Auditor}}">
                    <HBox class="sapUiMediumMargin" wrap="Wrap">
                        <GenericTile
                            header="{i18n>skillCategories}"
                            subheader="{i18n>systemSettings}"
                            press=".onNavToView('RouteSkillCategories')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <ImageContent src="sap-icon://list" />
                            </TileContent>
                        </GenericTile>

                        <GenericTile
                            header="{i18n>proficiencyLevels}"
                            subheader="{i18n>systemSettings}"
                            press=".onNavToView('RouteProficiencyLevels')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <ImageContent src="sap-icon://measure" />
                            </TileContent>
                        </GenericTile>

                        <GenericTile
                            header="{i18n>skillRequests}"
                            subheader="{i18n>systemSettings}"
                            press=".onNavToView('RouteSkillRequests')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <NumericContent value="{dashboardModel>/pendingRequests}" indicator="{= ${dashboardModel>/pendingRequests} > 0 ? 'Up' : 'None' }" icon="sap-icon://message-popup" valueColor="{= ${dashboardModel>/pendingRequests} > 0 ? 'Critical' : 'Good' }" />
                            </TileContent>
                        </GenericTile>

                        <GenericTile
                            header="Audit Events"
                            subheader="Security &amp; Audit Trail"
                            press=".onNavToView('RouteAuditLog')"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        >
                            <TileContent>
                                <ImageContent src="sap-icon://audit" />
                            </TileContent>
                        </GenericTile>
                    </HBox>
                </IconTabFilter>
            </items>
        </IconTabBar>
        <footer>
            <OverflowToolbar id="otbFooter">
                <Button
                    id="btnMessages"
                    icon="sap-icon://alert"
                    text="{=${message>/}.length}"
                    type="Emphasized"
                    press="onMessagePopoverPress"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
