<mvc:View
    controllerName="com.ndbs.skillreportingui.controller.Personnel"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:rowmodes="sap.ui.table.rowmodes"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:table="sap.ui.table"
    xmlns:core="sap.ui.core"
    xmlns:smartFilterBar="sap.ui.comp.smartfilterbar"
    xmlns:smartTable="sap.ui.comp.smarttable"
>
    <Page
        id="Personnel"
        showHeader="true"
        title="{i18n>personnel}"
        showNavButton="true"
        navButtonPress=".onNavBack"
    >
        <FlexBox
            justifyContent="Center"
            alignItems="Center"
        >
            <VBox width="95%">
                <smartFilterBar:SmartFilterBar
                    id="sfbPersonnel"
                    entitySet="VEmployees"
                    model="analytics"
                    useProvidedNavigationProperties="true"
                    initialise="onPersonnelInitialized"
                    enableBasicSearch="true"
                />
                <smartTable:SmartTable
                    id="stPersonnel"
                    entitySet="VEmployees"
                    model="analytics"
                    smartFilterId="sfbPersonnel"
                    tableType="ResponsiveTable"
                    enableExport="true"
                    useVariantManagement="false"
                    useTablePersonalisation="true"
                    showFullScreenButton="true"
                    header="{i18n>personnel}"
                    enableAutoBinding="true"
                    showRowCount="true"
                    requestAtLeastFields="fullName,employeeNumber,email,jobTitle,departmentName,managerName,isActive"
                    enableAutoColumnWidth="true"
                    editTogglable="false"
                >
                    <smartTable:customToolbar>
                        <OverflowToolbar design="Transparent">
                            <ToolbarSpacer />
                            <OverflowToolbarButton
                                id="btnCreateNewPersonnel"
                                icon="sap-icon://add"
                                press="onCreateNewPersonnel"
                            />
                            <OverflowToolbarButton
                                id="btnUpdatePersonnel"
                                icon="sap-icon://edit"
                                press="onUpdatePersonnel"
                            />
                            <OverflowToolbarButton
                                id="btnDeletePersonnel"
                                icon="sap-icon://delete"
                                press="onDeletePersonnel"
                            />
                            <Button
                                id="btnPersonnelUsers"
                                text="{i18n>personnelUsers}"
                                press="onDisplayPersonnelUsers"
                            />
                        </OverflowToolbar>
                    </smartTable:customToolbar>
                    <Table
                        id="uiTblPersonnel"
                        sticky="ColumnHeaders,HeaderToolbar"
                        mode="SingleSelectLeft"
                        growing="true"
                        growingThreshold="10"
                        growingScrollToLoad="false"
                    >
                        <columns>
                            <Column>
                                <customData>
                                    <core:CustomData key="p13nData" value='\{"columnKey": "fullName", "leadingProperty": "fullName", "sortProperty": "fullName", "filterProperty": "fullName"\}' />
                                </customData>
                                <Text text="{i18n>employeeName}" />
                            </Column>
                            <Column>
                                <customData>
                                    <core:CustomData key="p13nData" value='\{"columnKey": "employeeNumber", "leadingProperty": "employeeNumber", "sortProperty": "employeeNumber", "filterProperty": "employeeNumber"\}' />
                                </customData>
                                <Text text="Employee #" />
                            </Column>
                            <Column>
                                <customData>
                                    <core:CustomData key="p13nData" value='\{"columnKey": "email", "leadingProperty": "email", "sortProperty": "email", "filterProperty": "email"\}' />
                                </customData>
                                <Text text="Email" />
                            </Column>
                            <Column>
                                <customData>
                                    <core:CustomData key="p13nData" value='\{"columnKey": "jobTitle", "leadingProperty": "jobTitle", "sortProperty": "jobTitle", "filterProperty": "jobTitle"\}' />
                                </customData>
                                <Text text="Job Title" />
                            </Column>
                            <Column>
                                <customData>
                                    <core:CustomData key="p13nData" value='\{"columnKey": "departmentName", "leadingProperty": "departmentName", "sortProperty": "departmentName", "filterProperty": "departmentName"\}' />
                                </customData>
                                <Text text="Department" />
                            </Column>
                            <Column>
                                <customData>
                                    <core:CustomData key="p13nData" value='\{"columnKey": "managerName", "leadingProperty": "managerName", "sortProperty": "managerName", "filterProperty": "managerName"\}' />
                                </customData>
                                <Text text="Manager" />
                            </Column>
                            <Column hAlign="Center" width="5rem">
                                <customData>
                                    <core:CustomData key="p13nData" value='\{"columnKey": "isActive", "leadingProperty": "isActive", "sortProperty": "isActive", "filterProperty": "isActive"\}' />
                                </customData>
                                <Text text="{i18n>isActive}" />
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <ObjectIdentifier title="{fullName}" text="{jobTitle}" />
                                    <Text text="{employeeNumber}" />
                                    <Text text="{email}" />
                                    <Text text="{jobTitle}" />
                                    <Text text="{departmentName}" />
                                    <Text text="{managerName}" />
                                    <core:Icon
                                        src="{= ${isActive} ? 'sap-icon://accept' : 'sap-icon://decline'}"
                                        color="{= ${isActive} ? '#107E3E' : '#BB0000'}"
                                    />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </smartTable:SmartTable>
            </VBox>
        </FlexBox>
        <footer>
            <OverflowToolbar id="otbFooter">
                <Button
                    id="btnMessages"
                    icon="sap-icon://alert"
                    text="{=${message>/}.length}"
                    type="Emphasized"
                    press="onMessagePopoverPress"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
