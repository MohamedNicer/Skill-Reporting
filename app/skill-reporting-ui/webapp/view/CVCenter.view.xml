<mvc:View
    controllerName="com.ndbs.skillreportingui.controller.CVCenter"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:smartFilterBar="sap.ui.comp.smartfilterbar"
    xmlns:smartTable="sap.ui.comp.smarttable"
>
    <Page id="CVCenter" showHeader="false">
        <IconTabBar id="itbCVCenter" expandable="false" class="sapUiResponsiveContentPadding">
            <items>
                <IconTabFilter icon="sap-icon://upload" text="{i18n>uploadedCVs}">
                    <VBox width="100%">
                        <smartFilterBar:SmartFilterBar
                            id="sfbUploadedCVs"
                            entitySet="VUploadedCVs"
                        />
                        <smartTable:SmartTable
                            id="stUploadedCVs"
                            entitySet="VUploadedCVs"
                            smartFilterId="sfbUploadedCVs"
                            tableType="ResponsiveTable"
                            enableAutoBinding="true"
                            enableExport="true"
                            useVariantManagement="false"
                            useTablePersonalisation="true"
                            showFullScreenButton="true"
                            showRowCount="true"
                            editTogglable="false"
                            header="{i18n>uploadedCVs}"
                            initiallyVisibleFields="employeeName,fileName,mimeType,uploadStatusText,uploadedAt"
                        >
                            <smartTable:customToolbar>
                                <OverflowToolbar design="Transparent">
                                    <ToolbarSpacer />
                                    <Button
                                        id="btnUploadCV"
                                        text="{i18n>uploadCV}"
                                        icon="sap-icon://upload"
                                        press="onUploadCV"
                                        type="Emphasized"
                                    />
                                </OverflowToolbar>
                            </smartTable:customToolbar>
                            <Table id="tblUploadedCVs" sticky="ColumnHeaders,HeaderToolbar" />
                        </smartTable:SmartTable>
                    </VBox>
                </IconTabFilter>

                <IconTabFilter icon="sap-icon://pdf-attachment" text="{i18n>generatedCVs}">
                    <VBox width="100%">
                        <smartFilterBar:SmartFilterBar
                            id="sfbGeneratedCVs"
                            entitySet="VGeneratedCVs"
                        />
                        <smartTable:SmartTable
                            id="stGeneratedCVs"
                            entitySet="VGeneratedCVs"
                            smartFilterId="sfbGeneratedCVs"
                            tableType="ResponsiveTable"
                            enableAutoBinding="true"
                            enableExport="true"
                            useVariantManagement="false"
                            useTablePersonalisation="true"
                            showFullScreenButton="true"
                            showRowCount="true"
                            editTogglable="false"
                            header="{i18n>generatedCVs}"
                            initiallyVisibleFields="employeeName,templateName,fileName,generationStatusText,generatedAt"
                        >
                            <smartTable:customToolbar>
                                <OverflowToolbar design="Transparent">
                                    <ToolbarSpacer />
                                    <Button
                                        id="btnGenerateCV"
                                        text="{i18n>generateCV}"
                                        icon="sap-icon://create"
                                        press="onGenerateCV"
                                        type="Emphasized"
                                    />
                                </OverflowToolbar>
                            </smartTable:customToolbar>
                            <Table id="tblGeneratedCVs" sticky="ColumnHeaders,HeaderToolbar" />
                        </smartTable:SmartTable>
                    </VBox>
                </IconTabFilter>
            </items>
        </IconTabBar>

        <footer>
            <OverflowToolbar id="otbFooter">
                <Button
                    id="btnMessages"
                    icon="sap-icon://alert"
                    text="{=${message>/}.length}"
                    type="Emphasized"
                    press="onMessagePopoverPress"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
